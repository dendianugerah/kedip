{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kedip",
  "version": "0.2.3",
  "identifier": "com.dendianugerah.kedip",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEzMTE5MjU3NUZCRjJEMTEKUldRUkxiOWZWNUlSRTRrT1BiRWZINnhGVEZKNnFXcytLWUxSbHNRQy9oREE1Y1g0T2RjSTlXU3UK",
      "endpoints": [
        "https://github.com/dendianugerah/kedip/releases/latest/download/latest.json"
      ]
    }
  }
}
