{
  "name": "kedip",
  "private": true,
  "version": "0.1.0",
  "workspaces": ["apps/*"],
  "scripts": {
    "desktop:dev": "bun run --cwd apps/desktop tauri dev",
    "desktop:build": "bun run --cwd apps/desktop tauri build",
    "web:dev": "bun run --cwd apps/web dev",
    "web:build": "bun run --cwd apps/web build",
    "lint": "bun run --cwd apps/desktop lint",
    "format": "bun run --cwd apps/desktop format"
  }
}
